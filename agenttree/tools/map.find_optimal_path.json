{
  "id": "map.find_optimal_path",
  "description": "Find the optimal path between two campus buildings",
  "parameters": {
    "type": "object",
    "properties": {
      "source_building_id": {
        "type": "string",
        "description": "Starting building ID (e.g., 'B083')"
      },
      "target_building_id": {
        "type": "string",
        "description": "Destination building ID (e.g., 'B001')"
      },
      "constraints": {
        "type": "object",
        "description": "Optional constraints for path finding"
      }
    },
    "required": ["source_building_id", "target_building_id"]
  }
}
