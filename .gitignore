# Python
__pycache__/
*.py[cod]
*.so

# Node
node_modules/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Environment variables
.env
.env.local
.env.*.local
!.env.example

# Logs
*.log

# Runtime databases (mem0, vector store)
*.db

# Markdown (block stray docs, whitelist tree & system & docs content)
*.md
!README.md
!trees/**/*.md
!system/**/*.md
!docs/**/*.md

# YAML configs (keep)
!*.yaml
!benchmarks/**/*.yaml

# Development docs (local only)
develop_docs/

# Runtime worker directories (temp, per-run)
system/runs/

# Experiment outputs (large traces, generated at runtime)
experiments/

# Secrets
*api_key*
*apikey*
secrets/
credentials/
